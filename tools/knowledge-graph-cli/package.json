{
  "name": "knowledge-graph-cli",
  "version": "1.0.0",
  "description": "Knowledge graph CLI for iterative deep research",
  "type": "module",
  "bin": {
    "kg": "./src/cli/index.ts"
  },
  "scripts": {
    "kg": "bun run src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bun": "^1.2.8",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
