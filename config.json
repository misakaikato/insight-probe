{
  "name": "insight-probe",
  "version": "2.4.0",
  "description": "迭代式深度调研助手配置",

  "tools": {
    "searxng": {
      "endpoint": "http://127.0.0.1:10086",
      "format": "json",
      "timeout": 30000,
      "engines": ["google", "bing", "wikipedia"],
      "safe_search": 0,
      "categories": ["general", "news", "science"]
    },
    "opencli": {
      "enabled": true,
      "timeout": 30000,
      "max_concurrent": 5,
      "format": "json",
      "sites": [
        {
          "name": "wikipedia",
          "label": "维基百科",
          "command": "opencli wikipedia search \"{query}\" --lang zh --limit 30 -f json",
          "lang": "zh"
        },
        {
          "name": "wikipedia_en",
          "label": "Wikipedia",
          "command": "opencli wikipedia search \"{query}\" --lang en --limit 30 -f json",
          "lang": "en"
        },
        {
          "name": "zhihu",
          "label": "知乎",
          "command": "opencli zhihu search \"{query}\" --limit 30 -f json",
          "lang": "zh",
          "browser": true
        },
        {
          "name": "xiaohongshu",
          "label": "小红书",
          "command": "opencli xiaohongshu search \"{query}\" --limit 30 -f json",
          "lang": "zh",
          "browser": true
        },
        {
          "name": "bilibili",
          "label": "B站",
          "command": "opencli bilibili search \"{query}\" --limit 30 -f json",
          "lang": "zh",
          "browser": true
        },
        {
          "name": "weibo",
          "label": "微博",
          "command": "opencli weibo search \"{query}\" --limit 30 -f json",
          "lang": "zh",
          "browser": true
        },
        {
          "name": "douban_movie",
          "label": "豆瓣电影",
          "command": "opencli douban search \"{query}\" --type movie --limit 30 -f json",
          "lang": "zh",
          "browser": true
        },
        {
          "name": "douban_book",
          "label": "豆瓣图书",
          "command": "opencli douban search \"{query}\" --type book --limit 30 -f json",
          "lang": "zh",
          "browser": true
        },
        {
          "name": "hackernews",
          "label": "HackerNews",
          "command": "opencli hackernews search \"{query}\" --limit 30 -f json",
          "lang": "en"
        },
        {
          "name": "reddit",
          "label": "Reddit",
          "command": "opencli reddit search \"{query}\" --limit 30 -f json",
          "lang": "en"
        },
        {
          "name": "stackoverflow",
          "label": "StackOverflow",
          "command": "opencli stackoverflow search \"{query}\" --limit 30 -f json",
          "lang": "en"
        },
        {
          "name": "arxiv",
          "label": "ArXiv",
          "command": "opencli arxiv search \"{query}\" --limit 30 -f json",
          "lang": "en"
        },
        {
          "name": "v2ex",
          "label": "V2EX",
          "command": "opencli v2ex hot -f json",
          "lang": "zh",
          "note": "V2EX 无 search 命令，使用 hot 获取热门话题"
        },
        {
          "name": "xueqiu",
          "label": "雪球",
          "command": "opencli xueqiu search \"{query}\" --limit 30 -f json",
          "lang": "zh",
          "browser": true,
          "note": "仅搜索股票代码或名称，不适用于通用调研"
        }
      ]
    }
  },

  "research": {
    "max_rounds": 10,
    "queries_per_round": 8,
    "iteration_delay_ms": 1000,
    "stop_on_no_new_findings": 3
  },

  "output": {
    "format": "markdown",
    "include_timeline": true,
    "include_sources": true,
    "reliability_rating": true
  },

  "storage": {
    "temp_dir": "./temp",
    "per_topic_subdir": true,
    "save_search_results": true,
    "save_intermediate": true,
    "save_fetched_pages": true,
    "save_knowledge_graph": true,
    "max_file_age_hours": 24,
    "cleanup_on_exit": false
  },

  "knowledge_graph": {
    "enabled": true,
    "file": "knowledge_graph.json",
    "update_on_every_action": true,
    "node_types": ["topic", "search_query", "webpage", "finding", "question"]
  },

  "crawler": {
    "enabled": true,
    "max_pages_per_round": 5,
    "selection_strategy": "quality_based",
    "timeout": 30000,
    "follow_redirects": true,
    "max_depth": 1,
    "skip_media": true,
    "quality_threshold": 0.6
  }
}
